Options -Indexes
DirectoryIndex index.php

RewriteEngine On

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteRule ^api(/|$) - [F,L]

RewriteRule ^(index|status|projects|architecture|roadmap|operations|reference|login|account|benchmark-feedback|benchmark-feedback-results)\.html$ $1.php [R=301,L]

<FilesMatch "\.(env|ini|log|sql|bak)$">
    Require all denied
</FilesMatch>

<FilesMatch "^_.*\.php$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set X-Frame-Options "DENY"
</IfModule>
